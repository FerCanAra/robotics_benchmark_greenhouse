		   									<!-- Variables -->
	<!-- ================================================================================================ -->

	<variable name="NUM_TILTED_BEAMS_X" value="12"></variable>
	<variable name="NUM_TILTED_BEAMS_Y_ini" value="7"></variable>
	
	<variable name="NUM_CORRIDORS_X" value="5"></variable>
	
	<variable name="NUM_PLANTS_CORRIDOR_SOUTH" value="15"></variable>
	<variable name="NUM_PLANTS_CORRIDOR_NORTH" value="10"></variable>

	<variable name="NUM_POLES_X" value="5"></variable>
	<variable name="NUM_POLES_Y" value="5"></variable>

	<variable name="PLANTS_RAND_XY" value="0.35"></variable>
	
	<variable name="CEILING_HEIGHT" value="2.8"></variable>

	<variable name="greenhouse_x" value="20"></variable>
	<variable name="greenhouse_y" value="20"></variable>

