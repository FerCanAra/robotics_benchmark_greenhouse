	<!-- ================================================================================================ -->
		   							   <!-- Greenhouse definition -->
	<!-- ================================================================================================ -->

	<!-- H-beams along the X axis -->
	<for var="iX" from="0" to="$f{NUM_TILTED_BEAMS_X-1}">
		<block class="pole_tilted">
			<init_pose>$f{2*iX+2} 0.7 180</init_pose>
		</block>
		<block class="pole_tilted">
			<init_pose>$f{2*iX+2} $f{greenhouse_y+1.7} 0</init_pose>
		</block>
	</for>

	<!-- H-beams along the Y axis -->
	<for var="iY" from="0" to="$f{NUM_TILTED_BEAMS_Y_ini+2}">
		<block class="pole_tilted">
			<init_pose>1.7 $f{2+2*iY} 90</init_pose>
		</block>
	</for>
	<for var="iY" from="0" to="$f{NUM_TILTED_BEAMS_Y_ini+2}">
		<block class="pole_tilted">
			<init_pose>$f{greenhouse_x+4} $f{2+2*iY} -90</init_pose>
		</block>
	</for>

	<!-- Thick poles -->
	<for var="iX" from="0" to="2">
		<for var="iY" from="0" to="9">
			<if condition="$f{if(iY<=4 or iY>=5.5, 1, 0)}">
				<block class="pole_009">
					<init_pose>$f{4+8*iX} $f{3+2*iY} 0</init_pose>
				</block>
			</if>
		</for>
	</for>

	<!-- Thin poles -->
	<for var="iX" from="0" to="1">
		<for var="iY" from="0" to="9">
			<if condition="$f{if(iY<=4 or iY>=5.5, 1, 0)}">
				<block class="pole_004">
					<init_pose>$f{4+4+8*iX} $f{3+2*iY} 0</init_pose>
				</block>
			</if>
		</for>
	</for>
	
	<!-- Plants -->
	<for var="iX" from="0" to="$f{NUM_CORRIDORS_X-1}">
		<for var="iY" from="0" to="$f{NUM_PLANTS_CORRIDOR_SOUTH-1}">
			<block class="plant_tomato">
				<init_pose>$f{3.4+4*iX+rand()*PLANTS_RAND_XY} $f{1.5+iY*(11/NUM_PLANTS_CORRIDOR_SOUTH)+rand()*PLANTS_RAND_XY} $f{90}</init_pose>
			</block>
		</for>
		<for var="iY" from="0" to="$f{NUM_PLANTS_CORRIDOR_SOUTH-1}">
			<block class="plant_tomato">
				<init_pose>$f{4.6+4*iX+rand()*PLANTS_RAND_XY} $f{1.5+iY*(11/NUM_PLANTS_CORRIDOR_SOUTH)+rand()*PLANTS_RAND_XY} $f{90}</init_pose>
			</block>
		</for>
		<for var="iY" from="0" to="$f{NUM_PLANTS_CORRIDOR_NORTH-1}">
			<block class="plant_tomato">
				<init_pose>$f{3.4+4*iX+rand()*PLANTS_RAND_XY} $f{15.2+iY*(6/NUM_PLANTS_CORRIDOR_NORTH)+rand()*PLANTS_RAND_XY} $f{90}</init_pose>
			</block>
		</for>
		<for var="iY" from="0" to="$f{NUM_PLANTS_CORRIDOR_NORTH-1}">
			<block class="plant_tomato">
				<init_pose>$f{4.6+4*iX+rand()*PLANTS_RAND_XY} $f{15.2+iY*(6/NUM_PLANTS_CORRIDOR_NORTH)+rand()*PLANTS_RAND_XY} $f{90}</init_pose>
			</block>
		</for>
		
	</for> 

