<mvsim_world version="1.0">
	<!-- General simulation options -->
	<simul_timestep>0.001</simul_timestep>	<!-- Simulation fixed-time interval for numerical integration [seconds] or 0 to autodetermine -->
	<joystick_enabled>true</joystick_enabled>

	<georeference>
		<latitude>36.894718</latitude>
		<longitude>-2.316988</longitude>
		<height>200.0</height>
		<world_to_enu_rotation_deg>5.0</world_to_enu_rotation_deg>
	</georeference>

	<!-- ================================================================================================ -->
	<!-- GUI option -->
	<!-- ================================================================================================ -->
	<gui>
		<ortho>false</ortho>
		<show_forces>false</show_forces>
		<force_scale>0.01</force_scale>
		<cam_distance>10</cam_distance>
		<fov_deg>60</fov_deg>
		<refresh_fps>15</refresh_fps>
		<cam_point_to>1.5 13</cam_point_to>
		<!-- <follow_vehicle>r1</follow_vehicle> -->
	</gui>

	<!-- ================================================================================================ -->
	<!-- Light parameters -->
	<!-- ================================================================================================ -->

	<lights>
		<enable_shadows>true</enable_shadows>
		<shadow_map_size>1024</shadow_map_size>
		<light_azimuth_deg>-20.0</light_azimuth_deg>
		<light_elevation_deg>40.0</light_elevation_deg>
	</lights>

	<!-- ================================================================================================ -->
	<!-- Variables -->
	<!-- ================================================================================================ -->

	<variable name="NUM_TILTED_BEAMS_X" value="12"></variable>
	<variable name="NUM_TILTED_BEAMS_Y_ini" value="7"></variable>

	<variable name="NUM_CORRIDORS_X" value="5"></variable>

	<variable name="NUM_PLANTS_CORRIDOR_SOUTH" value="15"></variable>
	<variable name="NUM_PLANTS_CORRIDOR_NORTH" value="10"></variable>

	<variable name="NUM_POLES_X" value="5"></variable>
	<variable name="NUM_POLES_Y" value="5"></variable>

	<variable name="PLANTS_RAND_XY" value="0.35"></variable>

	<variable name="CEILING_HEIGHT" value="2.8"></variable>

	<variable name="greenhouse_x" value="20"></variable>
	<variable name="greenhouse_y" value="20"></variable>

	<!-- ================================================================================================ -->
	<!-- Scenario definition -->
	<!-- ================================================================================================ -->

	<!-- ground -->
	<variable name="MIN_ALT_M" value="$f{$env{MIN_ALT}}"/>
	<variable name="MAX_ALT_M" value="$f{$env{MAX_ALT}}"/>

	<element class='elevation_map'>
		<resolution>0.3</resolution>
		<elevation_image>elevation_mesh1.png</elevation_image>
		<elevation_image_min_z>$f{MIN_ALT_M}</elevation_image_min_z>
		<elevation_image_max_z>$f{MAX_ALT_M}</elevation_image_max_z>

		<texture_image>https://mrpt.github.io/mvsim-models/textures-cgbookcase/ForestFloor01_1K_BaseColor.png</texture_image>
		<texture_extension_x>1.0</texture_extension_x>
		<texture_extension_y>1.0</texture_extension_y>

		<texture>https://mrpt.github.io/mvsim-models/textures-cgbookcase/ForestFloor01_1K_BaseColor.png</texture>
		<texture_size_x>1.5</texture_size_x>
		<texture_size_y>1.5</texture_size_y>

		<corner_min_x>-2.5</corner_min_x>
		<corner_min_y>-5</corner_min_y>
		<model_split_size>3.0</model_split_size>		<!-- See docs. Required for correct z-order rendering if there are transparent objects in the world (e.g. trees with leaves) -->

		<mesh_color>#a0e0a0</mesh_color>		<!-- Used only if mesh_image is not provided -->
	</element>

	<!-- A SkyBox decoration -->
	<element class='skybox'>
		<!-- Provide the URI printf-like "pattern" to the six texture files, 
		     such that replacing "%s" with the following strings gives the path
		     to the files: "Up", "Right", "Left", "Front", "Down", "Back".
		 -->
		<textures>https://mrpt.github.io/mvsim-models/skyboxes/SunSet.zip/SunSet/SunSet%s.jpg</textures>
	</element>

	<!-- ================================================================================================ -->
	<!-- Robot definition -->
	<!-- ================================================================================================ -->

	<!-- ================= VEHICLE MASS VARIABLES ================= -->
	<variable name="BASE_MASS" value="70"/>
	<variable name="PAYLOAD" value="$f{$env{PAYLOAD_MASS}}"/>
	<variable name="mass" value="$f{BASE_MASS + PAYLOAD}"/>
	<variable name="USE_ADAP_FRICTION" value="$f{$env{USE_ADAPTATIVE_FRICTION}}"/>
	<include file="../robots/agricobiot.vehicle.xml" />
	<!-- ============= VEHICLE DEFINITION ================= -->
	<vehicle name="AGI" class="agricobiot">
		<init_pose>10.1 3 90</init_pose>

		<chassis mass="$f{mass}" />
		<log_path>./mvsim_logs/</log_path>
		<auto_start_recording>true</auto_start_recording>

		<include file="../sensors/rplidar-a2.sensor.xml" raytrace_3d="true" sensor_x="0" sensor_y="0" sensor_z="0.45" sensor_yaw="180" sensor_name="laser1" sensor_hz="10.0" />
		<include file="../sensors/rgbd_camera.sensor.xml" sensor_x="0.55" sensor_y="0" sensor_z="0.6" sensor_period_sec="0.10" show_3d_pointcloud="false" />
		<include file="../sensors/gnss.sensor.xml" sensor_x="0.0" sensor_y="0.0" sensor_z="0.25" sensor_period_sec="1.0" sensor_name="gps1" sensor_horizontal_std_noise="1.5" sensor_vertical_std_noise="2.5" />
		<include file="../sensors/imu.sensor.xml" sensor_x="0.0" sensor_y="0.05" sensor_z="0.145" sensor_period_sec="$f{1/200.0}" />

	</vehicle>

	<!-- ================================================================================================ -->
	<!-- Greenhouse Objetcs -->
	<!-- ================================================================================================ -->

	<!-- ======================================
	      Object types
	     ====================================== -->
	<block:class name="pole_tilted">
		<static>true</static>		<!-- Does not move -->
		<!-- <shape_from_visual/>  automatic shape,zmin,zmax from 3D mesh-->
		<!--  Custom visualization model. 3D model filename to load (local or remote http://uri ) -->
		<shape>
			<pt>-0.2 -0.7</pt>
			<pt>-0.2  1.0</pt>
			<pt> 0.2  1.0</pt>
			<pt> 0.2 -0.7</pt>
		</shape>
		<visual>
			<model_uri>https://mrpt.github.io/mvsim-models/greenhouse.zip/greenhouse/pole_tilted_he120e.stl</model_uri>
			<model_offset_z>1.2</model_offset_z>
			<model_roll>90.0</model_roll>
		</visual>
	</block:class>

	<block:class name="pole_009">
		<static>true</static>		<!-- Does not move -->
		<shape_from_visual/>
		<!-- automatic shape,zmin,zmax from 3D mesh-->
		<!--  Custom visualization model. 3D model filename to load (local or remote http://uri ) -->
		<visual>
			<model_uri>https://mrpt.github.io/mvsim-models/greenhouse.zip/greenhouse/pole_009.stl</model_uri>
			<model_offset_z>1.2</model_offset_z>
		</visual>
	</block:class>

	<block:class name="pole_004">
		<static>true</static>		<!-- Does not move -->
		<shape_from_visual/>
		<!-- automatic shape,zmin,zmax from 3D mesh-->
		<!--  Custom visualization model. 3D model filename to load (local or remote http://uri ) -->
		<visual>
			<model_uri>https://mrpt.github.io/mvsim-models/greenhouse.zip/greenhouse/pole_004.stl</model_uri>
			<model_offset_z>1.2</model_offset_z>
		</visual>
	</block:class>

	<block:class name="plant_tomato">
		<static>true</static>		<!-- Does not move -->
		<mass>5</mass>
		<!-- <shape_from_visual/>  automatic shape,zmin,zmax from 3D mesh-->
		<!--  Custom visualization model. 3D model filename to load (local or remote http://uri ) -->
		<shape>
			<pt>-0.5 -0.5</pt>
			<pt>-0.5  0.5</pt>
			<pt> 0.5  0.5</pt>
			<pt> 0.5 -0.5</pt>
		</shape>
		<visual>
			<model_uri>tomato_plant.dae</model_uri>
			<model_roll>90.0</model_roll>
			<model_offset_z>-0.05</model_offset_z>
		</visual>
	</block:class>


	<!-- ================================================================================================ -->
	<!-- Greenhouse definition -->
	<!-- ================================================================================================ -->

	<!-- H-beams along the X axis -->
	<for var="iX" from="0" to="$f{NUM_TILTED_BEAMS_X-1}">
		<block class="pole_tilted">
			<init_pose>$f{2*iX+2} 0.7 180</init_pose>
		</block>
		<block class="pole_tilted">
			<init_pose>$f{2*iX+2} $f{greenhouse_y+1.7} 0</init_pose>
		</block>
	</for>

	<!-- H-beams along the Y axis -->
	<for var="iY" from="0" to="$f{NUM_TILTED_BEAMS_Y_ini+2}">
		<block class="pole_tilted">
			<init_pose>1.7 $f{2+2*iY} 90</init_pose>
		</block>
	</for>
	<for var="iY" from="0" to="$f{NUM_TILTED_BEAMS_Y_ini+2}">
		<block class="pole_tilted">
			<init_pose>$f{greenhouse_x+4} $f{2+2*iY} -90</init_pose>
		</block>
	</for>

	<!-- Thick poles -->
	<for var="iX" from="0" to="2">
		<for var="iY" from="0" to="9">
			<if condition="$f{if(iY<=4 or iY>=5.5, 1, 0)}">
				<block class="pole_009">
					<init_pose>$f{4+8*iX} $f{3+2*iY} 0</init_pose>
				</block>
			</if>
		</for>
	</for>

	<!-- Thin poles -->
	<for var="iX" from="0" to="1">
		<for var="iY" from="0" to="9">
			<if condition="$f{if(iY<=4 or iY>=5.5, 1, 0)}">
				<block class="pole_004">
					<init_pose>$f{4+4+8*iX} $f{3+2*iY} 0</init_pose>
				</block>
			</if>
		</for>
	</for>

	<!-- Plants -->
	<for var="iX" from="0" to="$f{NUM_CORRIDORS_X-1}">
		<for var="iY" from="0" to="$f{NUM_PLANTS_CORRIDOR_SOUTH-1}">
			<block class="plant_tomato">
				<init_pose>$f{3.4+4*iX+rand()*PLANTS_RAND_XY} $f{1.5+iY*(11/NUM_PLANTS_CORRIDOR_SOUTH)+rand()*PLANTS_RAND_XY} $f{90}</init_pose>
			</block>
		</for>
		<for var="iY" from="0" to="$f{NUM_PLANTS_CORRIDOR_SOUTH-1}">
			<block class="plant_tomato">
				<init_pose>$f{4.6+4*iX+rand()*PLANTS_RAND_XY} $f{1.5+iY*(11/NUM_PLANTS_CORRIDOR_SOUTH)+rand()*PLANTS_RAND_XY} $f{90}</init_pose>
			</block>
		</for>
		<for var="iY" from="0" to="$f{NUM_PLANTS_CORRIDOR_NORTH-1}">
			<block class="plant_tomato">
				<init_pose>$f{3.4+4*iX+rand()*PLANTS_RAND_XY} $f{15.2+iY*(6/NUM_PLANTS_CORRIDOR_NORTH)+rand()*PLANTS_RAND_XY} $f{90}</init_pose>
			</block>
		</for>
		<for var="iY" from="0" to="$f{NUM_PLANTS_CORRIDOR_NORTH-1}">
			<block class="plant_tomato">
				<init_pose>$f{4.6+4*iX+rand()*PLANTS_RAND_XY} $f{15.2+iY*(6/NUM_PLANTS_CORRIDOR_NORTH)+rand()*PLANTS_RAND_XY} $f{90}</init_pose>
			</block>
		</for>

	</for>

	<!-- ================================================================================================ -->
	<!-- Friction zones as PropertyRegion elements (replacing AdaptativeFriction) -->
	<!-- ================================================================================================ -->
	<if condition="$f{USE_ADAP_FRICTION}">
		<!-- Friction zone: Solid Sand (mu=0.5) -->
		<element class="property_region">
			<property_name>friction_mu</property_name>
			<value_double>0.5</value_double>
			<x_min>2.0</x_min> <y_min>1.09</y_min> <z_min>-1.0</z_min>
			<x_max>24.7</x_max> <y_max>12.7</y_max> <z_max>3.0</z_max>
		</element>
		<element class="property_region">
			<property_name>friction_C_rr</property_name>
			<value_double>0.05</value_double>
			<x_min>2.0</x_min> <y_min>1.09</y_min> <z_min>-1.0</z_min>
			<x_max>24.7</x_max> <y_max>12.7</y_max> <z_max>3.0</z_max>
		</element>

		<!-- Friction zone: Cement (mu=0.9) -->
		<element class="property_region">
			<property_name>friction_mu</property_name>
			<value_double>0.9</value_double>
			<x_min>2.0</x_min> <y_min>12.7</y_min> <z_min>-1.0</z_min>
			<x_max>24.7</x_max> <y_max>15.0</y_max> <z_max>3.0</z_max>
		</element>
		<element class="property_region">
			<property_name>friction_C_rr</property_name>
			<value_double>0.01</value_double>
			<x_min>2.0</x_min> <y_min>12.7</y_min> <z_min>-1.0</z_min>
			<x_max>24.7</x_max> <y_max>15.0</y_max> <z_max>3.0</z_max>
		</element>

		<!-- Friction zone: Slim Sand (mu=0.2) -->
		<element class="property_region">
			<property_name>friction_mu</property_name>
			<value_double>0.2</value_double>
			<x_min>2.0</x_min> <y_min>15.0</y_min> <z_min>-1.0</z_min>
			<x_max>24.7</x_max> <y_max>21.6</y_max> <z_max>3.0</z_max>
		</element>
		<element class="property_region">
			<property_name>friction_C_rr</property_name>
			<value_double>0.10</value_double>
			<x_min>2.0</x_min> <y_min>15.0</y_min> <z_min>-1.0</z_min>
			<x_max>24.7</x_max> <y_max>21.6</y_max> <z_max>3.0</z_max>
		</element>
	</if>

</mvsim_world>
