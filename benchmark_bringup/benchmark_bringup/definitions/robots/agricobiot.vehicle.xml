<!--
  Vehicle class definition file.
  Intended to be included into world XML files.
  Common sensors could be included here, but they are left to be included in 
  class instantiations.
  Refer to mvsim_tutorial example files.
-->
<vehicle:class name="agricobiot">

    <!--  Dynamical model -->
    <dynamics class="differential_4_wheels">
        <!-- Params -->
        <lf_wheel pos="0.265  0.3" mass="3.0" width="0.1" diameter="0.32">
            <visual>
                <model_uri>../robots/husky-wheel.dae</model_uri>
                <model_yaw>0.0</model_yaw>
                <model_pitch>180.0</model_pitch>
                <model_roll>90.0</model_roll>
            </visual>
        </lf_wheel>
        <rf_wheel pos="0.265 -0.3" mass="3.0" width="0.1" diameter="0.32">
            <visual>
                <model_uri>../robots/husky-wheel.dae</model_uri>
                <model_yaw>0.0</model_yaw>
                <model_pitch>180.0</model_pitch>
                <model_roll>90.0</model_roll>
            </visual>
        </rf_wheel>
        <lr_wheel pos="-0.265  0.3" mass="3.0" width="0.1" diameter="0.32">
            <visual>
                <model_uri>../robots/husky-wheel.dae</model_uri>
                <model_yaw>0.0</model_yaw>
                <model_pitch>0.0</model_pitch>
                <model_roll>90.0</model_roll>
            </visual>
        </lr_wheel>
        <rr_wheel pos="-0.265 -0.3" mass="3.0" width="0.1" diameter="0.32">
            <visual>
                <model_uri>../robots/husky-wheel.dae</model_uri>
                <model_yaw>0.0</model_yaw>
                <model_pitch>0.0</model_pitch>
                <model_roll>90.0</model_roll>
            </visual>
        </rr_wheel>

        <chassis mass="70" zmin="0.05" zmax="0.25">
            <shape_from_visual/>
            <!-- automatic shape,zmin,zmax from 3D mesh-->
        </chassis>

        <!-- Tarea 1: Una clase en python del esqueo del controller del C++ -->
        <!-- PID EN PYHTON -->

        <!--   Motor controller -->
        <controller class="twist_pid">
            <!-- PID Params + Filter noise -->
            <!-- <KP>300</KP>  <KI>100</KI>  <KD>0</KD>  <N>0</N> -->
            <KP>70</KP>
            <KI>40</KI>
            <KD>0</KD>
            <N>0</N>
            <enable_antiwindup>true</enable_antiwindup>

            <!-- Feedforward Control -->
            <enable_feedforward>false</enable_feedforward>
            <K_ff>0.025</K_ff>
            <tau_ff>0.0</tau_ff>

            <!-- Adaptative feedforward tools -->
            <enable_adaptative>true</enable_adaptative>
            <full_payload>true</full_payload>
            <K_ff1>0.03</K_ff1>
            <tau_ff1>0.0</tau_ff1>            <!-- Empty payload in zone 1-->
            <K_ff2>0.025</K_ff2>
            <tau_ff2>0.0</tau_ff2>            <!-- Empty payload in zone 2 -->
            <K_ff3>0.02</K_ff3>
            <tau_ff3>0.0</tau_ff3>            <!-- Empty payload in zone 3 -->
            <K_ff4>0.05</K_ff4>
            <tau_ff4>0.0</tau_ff4>            <!-- Full payload in zone 1 Ok -->
            <K_ff5>0.02</K_ff5>
            <tau_ff5>0.0</tau_ff5>            <!-- Full payload in zone 2 Ok -->
            <K_ff6>0.015</K_ff6>
            <tau_ff6>0.0</tau_ff6>            <!-- Full payload in zone 3 -->
            <new_vel_max>90</new_vel_max>
            <new_w_max>90</new_w_max>
            <dist_obst>0.2</dist_obst>

            <!-- Consejo: Seleccione "AdaptativeFriction" para el modelo de friaccion-->

            <!-- Reference filter -->
            <enable_referencefilter>false</enable_referencefilter>
            <tau_f>0.5</tau_f>
            <n_f>1</n_f>

            <!-- Params for simulation. Real values of Husky Motor -->
            <!-- <I_MAX>6.1</I_MAX>
            <V>0.0</V><W>0</W>
            <max_torque>8</max_torque> -->

            <I_MAX>30</I_MAX>
            <V>0.0</V>
            <W>0</W>
            <max_torque>25</max_torque>

        </controller>

    </dynamics>

    <!-- Friction force simulation -->
    <friction class="AdaptativeFriction">
        <zones>
            <zone name="Solid Sand" mu="0.5" C_damping="1.0" Crr="0.05" x_min="2.0" x_max="24.7" y_min="1.09" y_max="12.7"/>
            <zone name="Cement" mu="0.9" C_damping="0.75" Crr="0.01" x_min="2.0" x_max="24.7" y_min="12.7" y_max="15.0"/>
            <zone name="Slim Sand" mu="0.2" C_damping="1.25" Crr="0.10" x_min="2" x_max="24.7" y_min="15" y_max="21.6"/>
        </zones>
    </friction>

    <!--  Custom visualization model -->
    <!-- 3D model filename to load (local or remote http://uri ) -->
    <visual>
        <model_uri>../robots/husky.dae</model_uri>
        <model_offset_z>0.12</model_offset_z>
        <model_yaw>0.0</model_yaw>
        <model_pitch>0.0</model_pitch>
        <model_roll>90.0</model_roll>
    </visual>

    <visual>
        <model_uri>../robots/top_chassis.dae</model_uri>
        <model_offset_z>0.12</model_offset_z>
        <model_yaw>0.0</model_yaw>
        <model_pitch>0.0</model_pitch>
        <model_roll>90.0</model_roll>
    </visual>

    <visual>
        <model_uri>../robots/top_plate.dae</model_uri>
        <model_offset_z>0.34</model_offset_z>
        <model_yaw>0.0</model_yaw>
        <model_pitch>0.0</model_pitch>
        <model_roll>90.0</model_roll>
    </visual>

    <visual>
        <model_uri>../robots/bumper.dae</model_uri>
        <model_offset_z>0.21</model_offset_z>
        <model_offset_x>0.49</model_offset_x>
        <model_yaw>180.0</model_yaw>
        <model_pitch>180.0</model_pitch>
        <model_roll>90.0</model_roll>
    </visual>

    <visual>
        <model_uri>../robots/bumper.dae</model_uri>
        <model_offset_z>0.21</model_offset_z>
        <model_offset_x>-0.49</model_offset_x>
        <model_yaw>180.0</model_yaw>
        <model_pitch>0.0</model_pitch>
        <model_roll>90.0</model_roll>
    </visual>

    <visual>
        <model_uri>../robots/Structure.dae</model_uri>
        <model_offset_z>0.15</model_offset_z>
        <model_yaw>90.0</model_yaw>
        <model_pitch>00.0</model_pitch>
        <model_roll>90.0</model_roll>
    </visual>

    <visual>
        <model_uri>../robots/Soporte_mastil.dae</model_uri>
        <model_offset_z>0.45</model_offset_z>
        <model_yaw>90.0</model_yaw>
        <model_pitch>0.0</model_pitch>
        <model_roll>90.0</model_roll>
    </visual>

    <visual>
        <model_uri>../robots/top_plate.dae</model_uri>
        <model_offset_z>0.34</model_offset_z>
        <model_yaw>0.0</model_yaw>
        <model_pitch>0.0</model_pitch>
        <model_roll>90.0</model_roll>
    </visual>

</vehicle:class>
