<controller class="twist_pid">

    <!-- PID -->
    <KP>70</KP>
    <KI>40</KI>
    <KD>0</KD>
    <N>0</N>
    <enable_antiwindup>true</enable_antiwindup>

    <!-- Feedforward -->
    <enable_feedforward>false</enable_feedforward>
    <K_ff>0.025</K_ff>
    <tau_ff>0.0</tau_ff>

    <!-- Adaptative feedforward -->
    <enable_adaptative>true</enable_adaptative>
    <full_payload>true</full_payload>

    <K_ff1>0.03</K_ff1>  <tau_ff1>0.0</tau_ff1>
    <K_ff2>0.025</K_ff2> <tau_ff2>0.0</tau_ff2>
    <K_ff3>0.02</K_ff3>  <tau_ff3>0.0</tau_ff3>
    <K_ff4>0.05</K_ff4>  <tau_ff4>0.0</tau_ff4>
    <K_ff5>0.02</K_ff5>  <tau_ff5>0.0</tau_ff5>
    <K_ff6>0.015</K_ff6> <tau_ff6>0.0</tau_ff6>

    <!-- Speed limits -->
    <new_vel_max>90</new_vel_max>
    <new_w_max>90</new_w_max>
    <dist_obst>0.2</dist_obst>

    <!-- Reference filter -->
    <enable_referencefilter>false</enable_referencefilter>
    <tau_f>0.5</tau_f>
    <n_f>1</n_f>

    <!-- Motor simulation -->
    <I_MAX>30</I_MAX>
    <V>0.0</V>
    <W>0.0</W>
    <max_torque>25</max_torque>

</controller>
